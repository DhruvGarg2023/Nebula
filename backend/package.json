{
  "name": "collaborative-code-editor-backend",
  "version": "0.1.0",
  "description": "Backend for Online Collaborative AI Code Editor",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:prod": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "healthcheck": "node -e \"fetch('http://localhost:3000/api/v1/health').then(r=>r.json()).then(d=>{ if(d.success) process.exit(0); else process.exit(1); }).catch(()=>process.exit(1))\""
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "collaborative",
    "code-editor",
    "real-time",
    "websocket"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.10"
  }
}
