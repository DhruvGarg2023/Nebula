// This is your Prisma schema file.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 1: Foundation — Users table only
// Additional tables will be added in subsequent milestones.
// ═══════════════════════════════════════════════════════════════

/// Enumeration of supported authentication providers.
enum AuthProvider {
  google
  github
  local
}

/// Role-based access control levels within a room.
enum Role {
  viewer
  editor
  admin
}

/// State of an invitation to join a room.
enum InvitationStatus {
  pending
  accepted
  expired
  revoked
}

/// Core user identity table.
/// Every entity in the system relates back to a user.
model User {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique @db.VarChar(255)
  name         String       @db.VarChar(100)
  avatarUrl    String?      @map("avatar_url") @db.Text
  preferences  Json         @default("{}") @db.JsonB
  authProvider AuthProvider @map("auth_provider")
  googleId     String?      @unique @map("google_id") @db.VarChar(255)
  passwordHash String?      @map("password_hash") @db.VarChar(255)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz()

  // Relations
  refreshTokens    RefreshToken[]
  ownedRooms       Room[]         @relation("RoomOwner")
  roomMemberships  RoomMember[]
  sentInvitations  Invitation[]   @relation("InvitationSender")
  messages         Message[]
  compilerJobs     CompilerJob[]

  // Indexes for common query patterns
  @@index([name], name: "idx_users_name")
  @@index([deletedAt], name: "idx_users_deleted_at")
  @@map("users")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 2: Authentication — RefreshTokens table
// ═══════════════════════════════════════════════════════════════

/// Stores hashed refresh tokens for JWT rotation.
/// Never stores raw tokens — only SHA-256 hashes.
/// Supports reuse detection: if a revoked token is reused,
/// all user tokens are revoked (indicates token theft).
model RefreshToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  userAgent String?  @map("user_agent") @db.Text
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  isRevoked Boolean  @default(false) @map("is_revoked")
  expiresAt DateTime @map("expires_at") @db.Timestamptz()
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "idx_refresh_tokens_user")
  @@index([expiresAt], name: "idx_refresh_tokens_expires")
  @@map("refresh_tokens")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 3: Room Management & RBAC
// ═══════════════════════════════════════════════════════════════

/// Collaborative room containing code files and chat.
model Room {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.Text
  language    String    @default("javascript") @db.VarChar(50)
  ownerId     String    @map("owner_id") @db.Uuid
  isPublic    Boolean   @default(false) @map("is_public")
  settings    Json      @default("{}") @db.JsonB
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz()
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz()

  // Relations
  owner       User          @relation("RoomOwner", fields: [ownerId], references: [id])
  members     RoomMember[]
  invitations Invitation[]
  files       File[]
  messages    Message[]
  compilerJobs CompilerJob[]

  @@index([ownerId], name: "idx_rooms_owner_id")
  @@index([createdAt(sort: Desc)], name: "idx_rooms_created_at")
  @@index([deletedAt], name: "idx_rooms_deleted_at")
  @@map("rooms")
}

/// Many-to-many junction table for Room Memberships.
model RoomMember {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role     @default(editor)
  joinedAt  DateTime @default(now()) @map("joined_at") @db.Timestamptz()

  // Relations
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Composite unique constraint: A user can only be a member of a room once
  @@unique([roomId, userId], map: "idx_room_members_room_user")
  @@index([userId], name: "idx_room_members_user_id")
  @@map("room_members")
}

/// Secure invitations to join a room.
model Invitation {
  id        String           @id @default(uuid()) @db.Uuid
  roomId    String           @map("room_id") @db.Uuid
  invitedBy String           @map("invited_by") @db.Uuid
  token     String           @unique @db.VarChar(64)
  role      Role             @default(editor)
  status    InvitationStatus @default(pending)
  expiresAt DateTime         @map("expires_at") @db.Timestamptz()
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  room      Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  inviter   User             @relation("InvitationSender", fields: [invitedBy], references: [id])

  @@index([roomId], name: "idx_invitations_room")
  @@index([expiresAt], name: "idx_invitations_expires")
  @@map("invitations")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 5: File Management
// ═══════════════════════════════════════════════════════════════

/// A code file belonging to a room.
model File {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @map("room_id") @db.Uuid
  name      String   @db.VarChar(255)
  language  String   @db.VarChar(50)
  content   String   @default("") @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz()

  // Relations
  room         Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  compilerJobs CompilerJob[]

  // A room cannot have two files with the exact same name
  @@unique([roomId, name], map: "idx_files_room_name")
  @@index([roomId], name: "idx_files_room_id")
  @@map("files")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 6: Chat System
// ═══════════════════════════════════════════════════════════════

/// Type of chat message.
enum MessageType {
  USER
  SYSTEM
}

/// A chat message within a room.
model Message {
  id        String      @id @default(uuid()) @db.Uuid
  roomId    String      @map("room_id") @db.Uuid
  userId    String?     @map("user_id") @db.Uuid
  content   String      @db.Text
  type      MessageType @default(USER)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz()

  // Relations
  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt(sort: Desc)], name: "idx_messages_room_created_at")
  @@map("messages")
}

// ═══════════════════════════════════════════════════════════════
// Milestone 7: Code Execution (Compiler)
// ═══════════════════════════════════════════════════════════════

/// Execution status for a compiler job.
enum JobStatus {
  queued
  running
  completed
  failed
  timeout
}

/// Audit log and execution details for code execution.
model CompilerJob {
  id              String    @id @default(uuid()) @db.Uuid
  roomId          String    @map("room_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  fileId          String?   @map("file_id") @db.Uuid
  language        String    @db.VarChar(50)
  sourceCode      String    @map("source_code") @db.Text
  stdout          String?   @db.Text
  stderr          String?   @db.Text
  exitCode        Int?      @map("exit_code")
  status          JobStatus @default(queued)
  executionTimeMs Int?      @map("execution_time_ms")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz()
  completedAt     DateTime? @map("completed_at") @db.Timestamptz()

  // Relations
  room Room  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  file File? @relation(fields: [fileId], references: [id], onDelete: SetNull)

  @@index([roomId, createdAt(sort: Desc)], name: "idx_compiler_jobs_room")
  @@index([userId, createdAt(sort: Desc)], name: "idx_compiler_jobs_user")
  @@map("compiler_jobs")
}
